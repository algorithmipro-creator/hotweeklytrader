ADMIN_WEB_LOGIN=owner
ADMIN_WEB_PASSWORD=<CHANGE_ME_OWNER_PASSWORD>
ADMIN_OWNER_TELEGRAM_ID=<YOUR_OWNER_ADMIN_TELEGRAM_ID>
REFERRAL_CAPTURE_SECRET=<CHANGE_ME_RANDOM_SECRET>

# Telegram
TELEGRAM_BOT_TOKEN=<YOUR_BOT_TOKEN>
TELEGRAM_BOT_NAME=<YOUR_BOT_USERNAME>
MINI_APP_URL=https://your-domain.com/
ADMIN_APP_URL=https://hotweeklytrader-admin.duckdns.org
ADMIN_TELEGRAM_IDS=<YOUR_ADMIN_TELEGRAM_ID>
