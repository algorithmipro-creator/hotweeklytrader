# ===== REQUIRED: Fill these before deploying =====

# Database
POSTGRES_USER=invest
POSTGRES_PASSWORD=<CHANGE_ME_SECURE_PASSWORD>
POSTGRES_DB=invest_db

# JWT
JWT_SECRET=<CHANGE_ME_64_CHAR_RANDOM_STRING>
JWT_EXPIRES_IN=24h

# Telegram
TELEGRAM_BOT_TOKEN=<YOUR_BOT_TOKEN>
TELEGRAM_BOT_NAME=<YOUR_BOT_USERNAME>
MINI_APP_URL=https://t.me/<YOUR_BOT_USERNAME>/app

# CORS - set to your domain
CORS_ORIGIN=https://your-domain.com

# Blockchain (optional - defaults to public RPCs)
BLOCKCHAIN_BSC_RPC_URL=https://bsc-dataseed.binance.org
BLOCKCHAIN_BSC_CONFIRMATIONS=12
BLOCKCHAIN_BSC_DEPOSIT_ADDRESS=0x1fFFbcda5bB208CbAd95882a9e57FA9354533AaC
BLOCKCHAIN_BSCSCAN_API_KEY=YourBscScanApiKey
BLOCKCHAIN_ETH_RPC_URL=https://eth.llamarpc.com
BLOCKCHAIN_ETH_CONFIRMATIONS=12
BLOCKCHAIN_TRON_RPC_URL=https://api.trongrid.io
BLOCKCHAIN_TRON_CONFIRMATIONS=19
