# Initial trader seed addresses (optional overrides)
SEED_FLUX_TRON_USDT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
SEED_FLUX_BSC_USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
