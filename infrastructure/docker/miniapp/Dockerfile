FROM node:20-alpine AS builder

WORKDIR /app

COPY apps/miniapp/package*.json ./
RUN npm install

COPY apps/miniapp/ ./
RUN npm run build

FROM node:20-alpine

WORKDIR /app

COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3001

ENV PORT=3001
CMD ["node", "server.js"]
